APP_NAME=SchemaPack Agent
APP_ENV=development
STORAGE_ROOT=storage
DATABASE_URL=sqlite:///./schemapack.db
LLM_MODE=mock
LLM_FALLBACK_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=0
LLM_MAX_SUGGESTIONS_PER_TASK=20
LLM_STRICT_FAILURE=false
EXTERNAL_UIR_LLM_ENABLED=false
EXTERNAL_UIR_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_MAX_RETRIES=0
DEEPSEEK_MAX_SUGGESTIONS_PER_REQUEST=20
DEEPSEEK_STRICT_JSON=true
OFFLINE_MODE=false
MAX_UPLOAD_BYTES=10485760
API_KEY_AUTH_ENABLED=false
API_KEYS=
AUDIT_LOG_ENABLED=true
AUDIT_LOG_BODY_MAX_CHARS=2000
ARTIFACT_RETENTION_ENABLED=false
ARTIFACT_RETENTION_DAYS=30
ARTIFACT_RETENTION_DRY_RUN=true
PACKAGE_DOWNLOAD_REQUIRES_AUTH=true
