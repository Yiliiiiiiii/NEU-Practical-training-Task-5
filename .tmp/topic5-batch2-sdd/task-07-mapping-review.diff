              "Last date on which grant proposals are accepted", +            ), +        ), +        ( +            "funding_ceiling", +            "number", +            False, +            ( +                "资助额度上限", +                "Funding ceiling", +                "Max grant", +                "单项最高支持金额", +                "Maximum funding available to one approved project", +            ), +        ), +        ( +            "award_amount", +            "number", +            False, +            ( +                "核定资助金额", +                "Approved grant", +                "Award amt.", +                "最终拨付金额", +                "Funding amount finally approved for an awardee", +            ), +        ), +    ), +} +DISTRACTORS = { +    "procurement_notice": ( +        "预算调整参考值", +        "award_amount", +        "budget is not award amount", +        "88000", +    ), +    "policy_release": ( +        "政策宣讲承办单位", +        "issuer", +        "organizer is not issuer", +        "Publicity Office", +    ), +    "meeting_record": ( +        "会务咨询联系人", +        "attendees", +        "contact is not attendee list", +        "Service Desk", +    ), +    "event_brief": ( +        "活动支持单位", +        "organizer", +        "sponsor is not organizer", +        "Community Sponsor", +    ), +    "service_guide": ( +        "业务咨询联系人", +        "service_object", +        "contact is not eligible audience", +        "Help Desk", +    ), +    "grant_program": ( +        "往年平均拨款", +        "funding_ceiling", +        "historical award is not current ceiling", +        "75000", +    ), +} + + +def dump_json(path: Path, value: Any) -> None: +    path.parent.mkdir(parents=True, exist_ok=True) +    path.write_text( +        json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n", +        encoding="utf-8", +    ) + + +def dump_jsonl(path: Path, rows: list[dict[str, Any]]) -> None: +    path.parent.mkdir(parents=True, exist_ok=True) +    path.write_text( +        "".join(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n" for row in rows), +        encoding="utf-8", +    ) + + +def schema_payload(family: str) -> dict[str, Any]: +    fields = [ +        { +            "field_id": field_id, +            "name": field_id, +            "display_name": field_id.replace("_", " ").title(), +            "type": field_type, +            "required": required, +            "aliases": list(labels), +            "constraints": {"format": "YYYY-MM-DD"} if field_type == "date" else {}, +        } +        for field_id, field_type, required, labels in FAMILY_FIELDS[family] +    ] +    return { +        "schema_id": family, +        "name": f"{family.replace('_', ' ').title()} Benchmark Schema", +        "version": "2.0.0", +        "description": "Frozen benchmark-only schema; grant_program is held out from tuning.", +        "fields": fields, +        "json_schema": { +            "type": "object", +            "required": [ +                field_id for field_id, _, required, _ in FAMILY_FIELDS[family] if required +            ], +            "properties": { +                field_id: {"type": "string" if field_type in {"string", "date"} else "number"} +                for field_id, field_type, _, _ in FAMILY_FIELDS[family] +            }, +        }, +    } + + +def rule_payload(family: str) -> dict[str, Any]: +    return { +        "template_id": f"{family}_mapping_v2", +        "schema_id": family, +        "name": f"{family} frozen benchmark rules", +        "version": "2.0.0", +        "aliases": {field_id: list(labels) for field_id, _, _, labels in FAMILY_FIELDS[family]}, +        "regex_rules": [], +        "transform_rules": [], +        "defaults": {}, +        "enum_maps": {}, +    } + + +def build(output: Path) -> None: +    if output.exists(): +        shutil.rmtree(output) +    output.mkdir(parents=True) +    manifests: list[dict[str, Any]] = [] +    gold_by_split: dict[str, list[dict[str, Any]]] = {"dev": [], "test": []} +    negatives: list[dict[str, Any]] = [] +    no_matches: list[dict[str, Any]] = [] +    split_docs: dict[str, list[str]] = {"dev": [], "test": []} +    required: dict[str, list[str]] = {} + +    for family_index, family in enumerate(FAMILIES): +        dump_json(output / "target_schemas" / f"{family}.json", schema_payload(family)) +        dump_json(output / "mapping_rules" / f"{family}.json", rule_payload(family)) +        required[family] = [ +            field_id for field_id, _, is_required, _ in FAMILY_FIELDS[family] if is_required +        ] +        for index in range(15): +            split = "test" if family == "grant_program" else ("dev" if index < 9 else "test") +            doc_id = f"mapv2-{family}-{index + 1:02d}" +            layout = ("key_value", "table", "paragraph")[index % 3] +            language = "zh-CN" if index % 2 == 0 else "en-US" +            organization = ( +                f"heldout-org-{family_index}-{index}" +                if split == "test" and index >= 12 +                else f"org-{family_index}-{index % 5}" +            ) +            held_out = split == "test" and (family == "grant_program" or index >= 12) +            labels = [] +            blocks: list[dict[str, Any]] = [] +            metadata: dict[str, Any] = { +                "domain": family, +                "language": language, +                "source_organization": organization, +            } +            order = list(FAMILY_FIELDS[family]) +            if index % 2: +                order.reverse() +            for position, ( +                field_id, +                field_type, +                required_field, +                field_labels, +            ) in enumerate(order): +                if not required_field and position == 0 and index % 5 == 0: +                    continue +                label = field_labels[(index + position) % len(field_labels)] +                labels.append(label) +                if position == 0: +                    value: Any = f"{family.replace('_', ' ').title()} item {index + 1}" +                elif field_type == "date": +                    value = f"2026-{((index + position) % 12) + 1:02d}-{(index % 20) + 1:02d}" +                elif field_type == "number": +                    value = str(100000 + index * 1000 + position * 100) +                elif position == 1: +                    value = f"Civic Organization {family_index + 1}-{index + 1}" +                else: +                    value = f"Recorded value {family_index + 1}-{index + 1}-{position + 1}" +                if position == 0 and index % 4 == 0: +                    metadata[label] = value +                    source_path = f"$.metadata.{label}" +                else: +                    block_id = f"b{position + 1:02d}" +                    block_type = "key_value" if layout == "key_value" else layout +                    blocks.append( +                        { +                            "block_id": block_id, +                            "type": block_type, +                            "text": f"{label}: {value}" +                            if block_type != "table" +                            else f"{label} | {value}", +                            "attributes": { +                                "field_name": label, +                                "benchmark_role": "source", +                            }, +                        } +                    ) +                    source_path = f"$.blocks.{block_id}.text" +                gold_by_split[split].append( +                    { +                        "doc_id": doc_id, +                        "schema_id": family, +                        "source_path": source_path, +                        "source_label": label, +                        "target_field_id": field_id, +                        "required": required_field, +                        "operation": "one_to_one", +                        "annotation_origin": "independent_frozen_author_label", +                    } +                ) +            distractor_id = "distractor" +            distractor_label, distractor_target, distractor_reason, distractor_value = DISTRACTORS[ +                family +            ] +            blocks.append( +                { +                    "block_id": distractor_id, +                    "type": "paragraph", +                    "text": f"{distractor_label}: {distractor_value}-{index + 1}", +                    "attributes": { +                        "field_name": distractor_label, +                        "benchmark_role": "distractor", +                    }, +                } +            ) +            distractor_path = f"$.blocks.{distractor_id}.text" +            negatives.append( +                { +                    "doc_id": doc_id, +                    "schema_id": family, +                    "source_path": distractor_path, +                    "target_field_id": distractor_target, +                    "reason": distractor_reason, +                } +            ) +            no_matches.append( +                { +                    "doc_id": doc_id, +                    "schema_id": family, +                    "source_path": distractor_path, +                    "decision": "no_match", +                    "reason": "compatible string distractor has no target", +                } +            ) +            uir = { +                "uir_version": "1.0", +                "doc_id": doc_id, +                "metadata": metadata, +                "blocks": blocks, +                "assets": [], +                "normalization_records": [], +            } +            uir_path = f"uir/{family}/{doc_id}.json" +            dump_json(output / uir_path, uir) +            split_docs[split].append(doc_id) +            manifests.append( +                { +                    "doc_id": doc_id, +                    "family": family, +                    "schema_id": family, +                    "uir_path": uir_path, +                    "target_schema_path": f"target_schemas/{family}.json", +                    "mapping_rule_path": f"mapping_rules/{family}.json", +                    "split": split, +                    "language": language, +                    "layout_pattern": layout, +                    "source_organization": organization, +                    "held_out_source_or_layout": held_out, +                    "schema_held_out": family == "grant_program" and split == "test", +                    "variety": [ +                        "zh_labels" if language == "zh-CN" else "en_labels", +                        "abbreviations" if index % 5 == 2 else "long_labels", +                        "metadata_candidates" +                        if index % 4 == 0 +                        else ("tables" if layout == "table" else f"{layout}_blocks"), +                        "field_order_changes" if index % 2 else "missing_optional_fields", +                        "multiple_date_types", +                        "semantic_distractors", +                        { +                            "procurement_notice": "budget_vs_award_amount", +                            "policy_release": "issuer_vs_organizer", +                            "meeting_record": "contact_vs_attendee", +                            "event_brief": "sponsor_vs_organizer", +                            "service_guide": "contact_vs_service_object", +                            "grant_program": "historical_award_vs_funding_ceiling", +                        }[family], +                        "publish_date_vs_effective_date" +                        if family == "policy_release" +                        else "distinct_date_roles", +                    ], +                    "source_labels": labels, +                } +            ) + +    dump_jsonl(output / "manifest.jsonl", manifests) +    dump_jsonl(output / "gold" / "dev.jsonl", gold_by_split["dev"]) +    dump_jsonl(output / "gold" / "test.jsonl", gold_by_split["test"]) +    dump_jsonl(output / "gold" / "negative_pairs.jsonl", negatives) +    dump_json(output / "gold" / "required_fields.json", required) +    dump_jsonl(output / "gold" / "no_match_cases.jsonl", no_matches) +    dump_json(output / "splits" / "dev.json", {"split": "dev", "doc_ids": split_docs["dev"]}) +    dump_json( +        output / "splits" / "test.json", +        {"split": "test", "doc_ids": split_docs["test"]}, +    ) +    dump_json( +        output / "splits" / "external_blind_manifest.json", +        { +            "status": "not_run", +            "reason": "independent annotations are not available", +            "runner": "scripts/run_topic5_mapping_v2_external_blind.py", +            "required_annotation_format": "gold-compatible JSONL", +        }, +    ) +    (output / "dataset_card.md").write_text( +        "# Topic 5 Mapping Benchmark v2\n\n" +        "Immutable public benchmark, version 2.0.0. It contains six genuinely " +        "distinct schema families, bilingual and non-exact labels, three layouts, " +        "metadata candidates, reordered/missing fields, and compatible-type " +        "distractors. Explicit contrasts cover budget versus award, issuer versus " +        "organizer, contact versus attendee, publish versus effective date, and " +        "other distinct date roles.\n\nGold labels were authored as standalone " +        "records by the deterministic fixture specification, never copied from " +        "engine predictions. The `grant_program` test subset is schema-held-out. " +        "Files under `uir/`, `target_schemas/`, `mapping_rules/`, `gold/`, and " +        "`splits/` are frozen; corrections require v3.\n", +        encoding="utf-8", +    ) +    write_hashes(output) + + +def write_hashes(output: Path) -> None: +    frozen = [ +        path +        for path in sorted(output.rglob("*")) +        if path.is_file() and path.name != "hashes.json" and "reports" not in path.parts +    ] +    files = { +        path.relative_to(output).as_posix(): hashlib.sha256(path.read_bytes()).hexdigest() +        for path in frozen +    } +    groups: dict[str, str] = {} +    for group in ("uir", "target_schemas", "mapping_rules", "gold", "splits"): +        rows = [ +            f"{name}:{digest}" for name, digest in files.items() if name.startswith(group + "/") +        ] +        groups[group] = hashlib.sha256("\n".join(rows).encode()).hexdigest() +    dataset_sha = hashlib.sha256( +        "\n".join(f"{name}:{digest}" for name, digest in files.items()).encode() +    ).hexdigest() +    dump_json( +        output / "hashes.json", +        { +            "dataset_id": "topic5_mapping_v2", +            "version": "2.0.0", +            "dataset_sha256": dataset_sha, +            "groups": groups, +            "files": files, +        }, +    ) + + +def main() -> None: +    parser = argparse.ArgumentParser(description=__doc__) +    parser.add_argument("--output", type=Path, default=DEFAULT_OUTPUT) +    args = parser.parse_args() +    build(args.output.resolve()) + + +if __name__ == "__main__": +    main() diff --git a/scripts/eval_topic5_mapping_v2.py b/scripts/eval_topic5_mapping_v2.py new file mode 100644 index 00000000..123b0622 --- /dev/null +++ b/scripts/eval_topic5_mapping_v2.py @@ -0,0 +1,459 @@ +"""Validate and evaluate the frozen Topic 5 mapping-v2 benchmark.""" + +from __future__ import annotations + +import argparse +import hashlib +import json +import subprocess +import sys +from collections import Counter, defaultdict +from dataclasses import dataclass +from pathlib import Path +from typing import Any + +ROOT = Path(__file__).resolve().parents[1] +DEFAULT_DATASET = ROOT / "eval" / "topic5_mapping_v2" + + +@dataclass(frozen=True) +class MappingV2Dataset: +    root: Path +    manifest: list[dict[str, Any]] +    uirs: dict[str, dict[str, Any]] +    schemas: dict[str, dict[str, Any]] +    rules: dict[str, dict[str, Any]] +    gold: dict[str, list[dict[str, Any]]] +    negative_pairs: list[dict[str, Any]] +    no_match_cases: list[dict[str, Any]] +    required_fields: dict[str, list[str]] +    splits: dict[str, list[str]] +    hashes: dict[str, Any] + + +def load_json(path: Path) -> Any: +    return json.loads(path.read_text(encoding="utf-8")) + + +def load_jsonl(path: Path) -> list[dict[str, Any]]: +    rows: list[dict[str, Any]] = [] +    for number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), 1): +        if not line.strip(): +            continue +        value = json.loads(line) +        if not isinstance(value, dict): +            raise ValueError(f"{path}:{number}: expected JSON object") +        rows.append(value) +    return rows + + +def load_dataset(root: Path) -> MappingV2Dataset: +    root = root.resolve() +    manifest = load_jsonl(root / "manifest.jsonl") +    schemas = { +        path.stem: load_json(path) for path in sorted((root / "target_schemas").glob("*.json")) +    } +    rules = {path.stem: load_json(path) for path in sorted((root / "mapping_rules").glob("*.json"))} +    return MappingV2Dataset( +        root=root, +        manifest=manifest, +        uirs={str(row["doc_id"]): load_json(root / str(row["uir_path"])) for row in manifest}, +        schemas=schemas, +        rules=rules, +        gold={split: load_jsonl(root / "gold" / f"{split}.jsonl") for split in ("dev", "test")}, +        negative_pairs=load_jsonl(root / "gold" / "negative_pairs.jsonl"), +        no_match_cases=load_jsonl(root / "gold" / "no_match_cases.jsonl"), +        required_fields=load_json(root / "gold" / "required_fields.json"), +        splits={ +            split: list(load_json(root / "splits" / f"{split}.json")["doc_ids"]) +            for split in ("dev", "test") +        }, +        hashes=load_json(root / "hashes.json"), +    ) + + +def verify_frozen_hashes(root: Path) -> None: +    payload = load_json(root / "hashes.json") +    actual: dict[str, str] = {} +    for name, expected in payload.get("files", {}).items(): +        path = root / name +        if not path.is_file(): +            raise ValueError(f"frozen file drift: missing {name}") +        digest = hashlib.sha256(path.read_bytes()).hexdigest() +        actual[name] = digest +        if digest != expected: +            raise ValueError(f"frozen file drift: {name}") +    dataset_sha = hashlib.sha256( +        "\n".join(f"{name}:{digest}" for name, digest in actual.items()).encode() +    ).hexdigest() +    if dataset_sha != payload.get("dataset_sha256"): +        raise ValueError("frozen file drift: dataset SHA") + + +def audit_leakage(dataset: MappingV2Dataset) -> dict[str, Any]: +    violations: list[dict[str, str]] = [] +    gold_by_doc: dict[str, list[dict[str, Any]]] = defaultdict(list) +    for row in dataset.gold["dev"] + dataset.gold["test"]: +        gold_by_doc[str(row["doc_id"])].append(row) +    for manifest in dataset.manifest: +        doc_id = str(manifest["doc_id"]) +        uir = dataset.uirs[doc_id] +        target_ids = {str(row["target_field_id"]) for row in gold_by_doc[doc_id]} +        if any(target_id in doc_id for target_id in target_ids): +            violations.append({"doc_id": doc_id, "kind": "target_id_in_doc_id"}) +        for block in uir.get("blocks", []): +            field_name = str(block.get("attributes", {}).get("field_name", "")) +            if field_name in target_ids: +                violations.append({"doc_id": doc_id, "kind": "target_id_in_field_name"}) +            hints = block.get("attributes", {}).get("candidate_hints", []) +            if any(str(hint) in target_ids for hint in hints if hint): +                violations.append({"doc_id": doc_id, "kind": "target_id_in_candidate_hint"}) +    return {"passed": not violations, "violations": violations} + + +def validate_dataset(dataset: MappingV2Dataset) -> dict[str, Any]: +    verify_frozen_hashes(dataset.root) +    if len(dataset.manifest) != len({str(row.get("doc_id")) for row in dataset.manifest}): +        r