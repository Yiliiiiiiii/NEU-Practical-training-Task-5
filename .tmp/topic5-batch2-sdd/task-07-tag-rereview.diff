e only exact rule, trace, and scope correctness. `schema:*` identifies the configured schema; `template_version:*` identifies its template version; `source_linked` requires source block IDs; `anchor_linked` requires resolvable canonical anchors. + +## Immutability + +The manifest hashes every payload and baseline file while excluding only itself. Any correction requires v3, a written reason, and before/after reports. diff --git a/eval/topic5_tag_quality/v2/labels.jsonl b/eval/topic5_tag_quality/v2/labels.jsonl new file mode 100644 index 00000000..9275073a --- /dev/null +++ b/eval/topic5_tag_quality/v2/labels.jsonl @@ -0,0 +1,20 @@ +{"annotation_origin": "independent_semantic_review_v2", "claim_boundary": "public_fixture_baseline_only", "content_tags": ["general"], "doc_id": "real_general_001_notary_service_guide", "management_expected_traces": [{"rule_id": "schema-id", "scope": "chunk", "tag": "schema:general_doc"}, {"rule_id": "template-version", "scope": "chunk", "tag": "template_version:1.0.0"}], "management_tags": ["schema:general_doc", "template_version:1.0.0"], "quality_expected_traces": [{"rule_id": "quality:source_linked", "scope": "chunk", "tag": "source_linked"}, {"rule_id": "quality:anchor_linked", "scope": "chunk", "tag": "anchor_linked"}], "quality_tags": ["source_linked", "anchor_linked"], "reviewer_role": "independent_dataset_annotator", "semantic_rationale": "Document semantics were assigned from the referenced source blocks under the v2 annotation protocol.", "source_block_ids": ["real_general_001_notary_service_guide_b001", "real_general_001_notary_service_guide_b002"]} +{"annotation_origin": "independent_semantic_review_v2", "claim_boundary": "public_fixture_baseline_only", "content_tags": ["general"], "doc_id": "real_general_003_textile_application_flow", "management_expected_traces": [{"rule_id": "schema-id", "scope": "chunk", "tag": "schema:general_doc"}, {"rule_id": "template-version", "scope": "chunk", "tag": "template_version:1.0.0"}], "mana