urce_sha256": "30c89f1c9480fc47dd83038dbc38198ad7b0f25adb5182bc7806b972c18bbf39"} +{"doc_id": "real_policy_007_one_thing_list", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/policy/real_policy_007_one_thing_list.json", "source_sha256": "29cb077d8b76611a7753396fc6058231e68a6a2ad785fa7a6cfbc9f3add31ccb"} +{"doc_id": "real_policy_008_sme_leader_training", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/policy/real_policy_008_sme_leader_training.json", "source_sha256": "fd779cea3fd7dc8abf469191c0d80b04ec953cd5d0a4feb34f8ffce255bbd35b"} +{"doc_id": "real_policy_009_network_safety_work", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/policy/real_policy_009_network_safety_work.json", "source_sha256": "9bf530b8f29feee4786609f417077eef00754917c8d474ee107e6f5df4d61743"} +{"doc_id": "real_policy_010_auto_ota_management", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/policy/real_policy_010_auto_ota_management.json", "source_sha256": "1efa604dbd3bdab8138d035cd4e1022479aa82514f302054082f1e4839ed252b"} +{"doc_id": "real_procurement_001_broadcast_security_supervision", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/procurement/real_procurement_001_broadcast_security_supervision.json", "source_sha256": "907c08a2ea8ab0fcfc02f9389f15b59b393e78f446beff58f67e1fa698838fa4"} +{"doc_id": "real_procurement_002_special_equipment_bid", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/procurement/real_procurement_002_special_equipment_bid.json", "source_sha256": "f60886f08e54414589861c9320b1ce1559c64dac9f321a1a0d67c74ad8710c3f"} +{"doc_id": "real_procurement_003_radiation_monitoring_award", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/procurement/real_procurement_003_radiation_monitoring_award.json", "source_sha256": "b9391ccc4bf33be233c253affecf10d0aa0ea5baa1b9d6e5b692fc9749b1f6ab"} +{"doc_id": "real_procurement_004_veterinary_platform_award", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/procurement/real_procurement_004_veterinary_platform_award.json", "source_sha256": "44909fa321ec6fab86e38da1cf736d6b4e6d959bf417ac32d80d510270ba8ff2"} +{"doc_id": "real_procurement_005_rehabilitation_equipment_award", "snapshot_scope": "referenced UIR plus frozen source hash", "source_path": "examples/real_world/uir/procurement/real_procurement_005_rehabilitation_equipment_award.json", "source_sha256": "89e0a287554d1728ea34da8a12c4657d66281b3ecbc7e01be06ed04eb5c6da1f"} diff --git a/eval/topic5_tag_quality/v2/taxonomy.json b/eval/topic5_tag_quality/v2/taxonomy.json new file mode 100644 index 00000000..3a8230d8 --- /dev/null +++ b/eval/topic5_tag_quality/v2/taxonomy.json @@ -0,0 +1,19 @@ +{ +  "content": [ +    "general", +    "meeting", +    "policy", +    "procurement" +  ], +  "management": [ +    "schema:general_doc", +    "schema:meeting_doc", +    "schema:policy_doc", +    "schema:procurement_doc", +    "template_version:1.0.0" +  ], +  "quality": [ +    "anchor_linked", +    "source_linked" +  ] +} diff --git a/scripts/build_topic5_tag_quality_v2_dataset.py b/scripts/build_topic5_tag_quality_v2_dataset.py new file mode 100644 index 00000000..d3817723 --- /dev/null +++ b/scripts/build_topic5_tag_quality_v2_dataset.py @@ -0,0 +1,122 @@ +"""Freeze independently reviewed tag-quality v2 labels and source references.""" + +from __future__ import annotations + +import argparse +import hashlib +import json +import shutil +from pathlib import Path +from typing import Any + + +ROOT = Path(__file__).resolve().parents[1] +SOURCE_GOLD = ROOT / "examples" / "real_world" / "gold" / "content_organization_gold.jsonl" +SOURCE_UIR = ROOT / "examples" / "real_world" / "uir" +DEFAULT_OUTPUT = ROOT / "eval" / "topic5_tag_quality" / "v2" + + +def load_jsonl(path: Path) -> list[dict[str, Any]]: +    return [json.loads(line) for line in path.read_text(encoding="utf-8").splitlines() if line.strip()] + + +def dump_json(path: Path, value: Any) -> None: +    path.write_text(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8") + + +def dump_jsonl(path: Path, rows: list[dict[str, Any]]) -> None: +    path.write_text("".join(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n" for row in rows), encoding="utf-8") + + +def build(output: Path) -> None: +    if output.exists(): +        shutil.rmtree(output) +    output.mkdir(parents=True) +    source_rows = load_jsonl(SOURCE_GOLD) +    uir_paths = { +        str(payload["doc_id"]): path +        for path in sorted(SOURCE_UIR.glob("*/*.json")) +        if path.parent.name != "_rejected" +        for payload in [json.loads(path.read_text(encoding="utf-8"))] +    } +    labels: list[dict[str, Any]] = [] +    references: list[dict[str, Any]] = [] +    taxonomy = {"content": set(), "management": set(), "quality": set()} +    for row in source_rows: +        doc_id = str(row["doc_id"]) +        content = list(map(str, row["expected_content_tags"])) +        management = list(map(str, row["expected_management_tags"])) +        quality = list(map(str, row["expected_quality_tags"])) +        labels.append( +            { +                "doc_id": doc_id, +                "source_block_ids": list(map(str, row["source_block_ids"])), +                "content_tags": content, +                "management_tags": management, +                "quality_tags": quality, +                "annotation_origin": "independent_semantic_review_v2", +                "management_expected_traces": [ +                    {"tag": tag, "rule_id": "schema-id" if tag.startswith("schema:") else "template-version", "scope": "chunk"} +                    for tag in management +                ], +                "quality_expected_traces": [ +                    {"tag": tag, "rule_id": f"quality:{tag}", "scope": "chunk"} +                    for tag in quality +                ], +            } +        ) +        for category, tags in (("content", content), ("management", management), ("quality", quality)): +            taxonomy[category].update(tags) +        source_path = uir_paths[doc_id] +        references.append( +            { +                "doc_id": doc_id, +                "source_path": source_path.relative_to(ROOT).as_posix(), +                "source_sha256": hashlib.sha256(source_path.read_bytes()).hexdigest(), +                "snapshot_scope": "referenced UIR plus frozen source hash", +            } +        ) +    dump_jsonl(output / "labels.jsonl", labels) +    dump_jsonl(output / "source_uir_refs.jsonl", references) +    dump_json(output / "taxonomy.json", {key: sorted(value) for key, value in taxonomy.items()}) +    (output / "dataset_card.md").write_text( +        "# Topic 5 Tag Quality v2\n\n" +        "Version 2.0.0 is an immutable independent label freeze over source-hashed real-world UIR references. " +        "Content tags describe document semantics and are scored with precision, recall, and F1. " +        "Management tags identify the schema/template rule outputs; quality tags localize source/anchor integrity. " +        "Management and quality are deterministic checks and are reported only as rule, trace, and scope correctness.\n\n" +        "`schema:*` means the configured target schema, `template_version:*` the configured template version, " +        "`source_linked` requires declared source blocks, and `anchor_linked` requires resolvable anchors. " +        "The v2 labels, references, taxonomy, and card are frozen after baseline; corrections require v3 with a written reason.\n", +        encoding="utf-8", +    ) +    dump_json( +        output / "manifest.json", +        { +            "dataset_id": "topic5_tag_quality", +            "version": "2.0.0", +            "label_count": len(labels), +            "source_reference_count": len(references), +            "immutable": True, +            "correction_policy": "create v3 with a written reason and before/after reports", +        }, +    ) +    files = { +        path.name: hashlib.sha256(path.read_bytes()).hexdigest() +        for path in sorted(output.iterdir()) +        if path.is_file() and path.name != "hashes.json" +    } +    dataset_sha = hashlib.sha256("\n".join(f"{name}:{digest}" for name, digest in files.items()).encode()).hexdigest() +    dump_json(output / "hashes.json", {"dataset_id": "topic5_tag_quality", "version": "2.0.0", "dataset_sha256": dataset_sha, "files": files}) +    (output / "dataset.sha256").write_text(dataset_sha + "\n", encoding="utf-8") + + +def main() -> None: +    parser = argparse.ArgumentParser(description=__doc__) +    parser.add_argument("--output", type=Path, default=DEFAULT_OUTPUT) +    args = parser.parse_args() +    build(args.output.resolve()) + + +if __name__ == "__main__": +    main() diff --git a/scripts/eval_topic5_tag_quality_v2.py b/scripts/eval_topic5_tag_quality_v2.py new file mode 100644 index 00000000..4c3d6583 --- /dev/null +++ b/scripts/eval_topic5_tag_quality_v2.py @@ -0,0 +1,226 @@ +"""Evaluate immutable Topic 5 tag-quality v2 labels.""" + +from __future__ import annotations + +import argparse +import hashlib +import importlib.util +import json +import subprocess +import sys +from dataclasses import dataclass +from pathlib import Path +from typing import Any + + +ROOT = Path(__file__).resolve().parents[1] +DEFAULT_DATASET = ROOT / "eval" / "topic5_tag_quality" / "v2" + + +@dataclass +class TagV2Dataset: +    root: Path +    labels: list[dict[str, Any]] +    references: list[dict[str, Any]] +    taxonomy: dict[str, list[str]] +    hashes: dict[str, Any] + + +def load_json(path: Path) -> Any: +    return json.loads(path.read_text(encoding="utf-8")) + + +def load_jsonl(path: Path) -> list[dict[str, Any]]: +    return [json.loads(line) for line in path.read_text(encoding="utf-8").splitlines() if line.strip()] + + +def load_dataset(root: Path) -> TagV2Dataset: +    return TagV2Dataset( +        root=root.resolve(), +        labels=load_jsonl(root / "labels.jsonl"), +        references=load_jsonl(root / "source_uir_refs.jsonl"), +        taxonomy=load_json(root / "taxonomy.json"), +        hashes=load_json(root / "hashes.json"), +    ) + + +def verify_frozen_hashes(root: Path) -> None: +    payload = load_json(root / "hashes.json") +    actual: dict[str, str] = {} +    for name, expected in payload["files"].items(): +        path = root / name +        if not path.is_file(): +            raise ValueError(f"frozen file drift: missing {name}") +        digest = hashlib.sha256(path.read_bytes()).hexdigest() +        actual[name] = digest +        if digest != expected: +            raise ValueError(f"frozen file drift: {name}") +    combined = hashlib.sha256("\n".join(f"{name}:{digest}" for name, digest in actual.items()).encode()).hexdigest() +    if combined != payload["dataset_sha256"]: +        raise ValueError("frozen file drift: dataset SHA") +    if (root / "dataset.sha256").read_text(encoding="utf-8").strip() != combined: +        raise ValueError("frozen file drift: dataset.sha256") + + +def _load_uir(reference: dict[str, Any]) -> dict[str, Any]: +    path = ROOT / str(reference["source_path"]) +    if hashlib.sha256(path.read_bytes()).hexdigest() != reference["source_sha256"]: +        raise ValueError(f"source UIR drift: {reference['doc_id']}") +    return load_json(path) + + +def validate_dataset(dataset: TagV2Dataset) -> None: +    references = {str(row["doc_id"]): row for row in dataset.references} +    if len(dataset.labels) < 20: +        raise ValueError("tag v2 requires at least 20 label rows") +    for row in dataset.labels: +        doc_id = str(row.get("doc_id", "")) +        if doc_id not in references: +            raise ValueError(f"unknown source UIR: {doc_id}") +        uir = _load_uir(references[doc_id]) +        block_ids = {str(block["block_id"]) for block in uir.get("blocks", [])} +        unknown_blocks = set(map(str, row.get("source_block_ids", []))) - block_ids +        if unknown_blocks: +            raise ValueError(f"unknown block reference: {sorted(unknown_blocks)[0]}") +        for category in ("content", "management", "quality"): +            tags = row.get(f"{category}_tags") +            if not isinstance(tags, list) or not tags: +                raise ValueError(f"{doc_id}: {category}_tags must be non-empty") +            unknown = set(map(str, tags)) - set(dataset.taxonomy[category]) +            if unknown: +                raise ValueError(f"unknown {category} tag: {sorted(unknown)[0]}") + + +def _old_module(): +    path = ROOT / "scripts" / "eval_content_tag_quality.py" +    spec = importlib.util.spec_from_file_location("_tag_v2_runtime", path) +    if spec is None or spec.loader is None: +        raise RuntimeError("cannot load tag runtime") +    module = importlib.util.module_from_spec(spec) +    spec.loader.exec_module(module) +    return module + + +def ratio(numerator: int, denominator: int) -> float: +    return float(numerator) / float(denominator) if denominator else 0.0 + + +def git_head() -> str: +    return subprocess.check_output( +        ["git", "rev-parse", "HEAD"], cwd=ROOT, text=True +    ).strip() + + +def _correctness(expected: set[str], actual: set[str]) -> dict[str, Any]: +    return {"correct": expected == actual, "expected": sorted(expected), "actual": sorted(actual)} + + +def _trace_sets(chunks: list[dict[str, Any]]) -> tuple[set[tuple[str, str, str]], set[tuple[str, str]]]: +    traces = { +        (str(trace.get("tag")), str(trace.get("rule_id")), str(trace.get("scope"))) +        for chunk in chunks +        for trace in chunk.get("organization_trace", {}).get("tag_traces", []) +    } +    scopes = {(tag, scope) for tag, _, scope in traces} +    return traces, scopes + + +def evaluate(root: Path) -> dict[str, Any]: +    dataset = load_dataset(root) +    verify_frozen_hashes(root) +    validate_dataset(dataset) +    runtime = _old_module() +    uirs = {str(ref["doc_id"]): _load_uir(ref) for ref in dataset.references} +    chunks = runtime.RETRIEVAL.generate_chunks_for_strategy(uirs, strategy="heading_aware") +    content_tp = content_predicted = content_expected = unknown = 0 +    details: list[dict[str, Any]] = [] +    management_correct: list[bool] = [] +    quality_correct: list[bool] = [] +    management_trace_correct: list[bool] = [] +    management_scope_correct: list[bool] = [] +    quality_trace_correct: list[bool] = [] +    quality_scope_correct: list[bool] = [] +    for label in dataset.labels: +        doc_id = str(label["doc_id"]) +        relevant = runtime.relevant_chunks({"source_block_ids": label["source_block_ids"]}, chunks.get(doc_id, [])) +        actual = { +            category: runtime._collect_tags(relevant, f"{category}_tags") +            for category in ("content", "management", "quality") +        } +        expected = {category: set(map(str, label[f"{category}_tags"])) for category in ("content", "management", "quality")} +        actual_traces, actual_scopes = _trace_sets(relevant) +        management_traces = { +            (str(row["tag"]), str(row["rule_id"]), str(row["scope"])) +            for row in label["management_expected_traces"] +        } +        quality_traces = { +            (str(row["tag"]), str(row["rule_id"]), str(row["scope"])) +            for row in label["quality_expected_traces"] +        } +        content_tp += len(actual["content"] & expected["content"]) +        content_predicted += len(actual["content"]) +        content_expected += len(expected["content"]) +        for category in actual: +            unknown += len(actual[category] - set(dataset.taxonomy[category])) +        management_correct.append(actual["management"] == expected["management"]) +        quality_correct.append(actual["quality"] == expected["quality"]) +        management_trace_correct.append(management_traces <= actual_traces) +        quality_trace_correct.append(quality_traces <= actual_traces) +        management_scope_correct.append({(tag, "chunk") for tag in expected["management"]} <= actual_scopes) +        quality_scope_correct.append({(tag, "chunk") for tag in expected["quality"]} <= actual_scopes) +        details.append( +            { +                "doc_id": doc_id, +                "content_semantic": { +                    "expected": sorted(expected["content"]), +                    "actual": sorted(actual["content"]), +                }, +                "management": _correctness(expected["management"], actual["management"]), +                "quality": _correctness(expected["quality"], actual["quality"]), +            } +        ) +    precision = ratio(content_tp, content_predicted) +    recall = ratio(content_tp, content_expected) +    management_rate = ratio(sum(management_correct), len(management_correct)) +    quality_rate = ratio(sum(quality_correct), len(quality_correct)) +    management_trace_rate = ratio(sum(management_trace_correct), len(management_trace_correct)) +    management_scope_rate = ratio(sum(management_scope_correct), len(management_scope_correct)) +    quality_trace_rate = ratio(sum(quality_trace_correct), len(quality_trace_correct)) +    quality_scope_rate = ratio(sum(quality_scope_correct), len(quality_scope_correct)) +    def correctness(value: float) -> dict[str, Any]: +        return {"passed": value == 1.0, "rate": value} +    return { +        "status": "completed", +        "baseline_source_commit": git_head(), +        "dataset": {"id": dataset.hashes["dataset_id"], "version": dataset.hashes["version"], "sha256": dataset.hashes["dataset_sha256"]}, +        "sample_count": len(dataset.labels), +        "metrics": { +            "content_semantic": {"precision": precision, "recall": recall, "f1": ratio(2 * precision * recall, precision + recall)}, +            "management_rule_correctness": correctness(management_rate), +            "management_trace_correctness": correctness(management_trace_rate), +            "management_scope_correctness": correctness(management_scope_rate), +            "quality_rule_correctness": correctness(quality_rate), +            "quality_trace_correctness": correctness(quality_trace_rate), +            "quality_scope_correctness": correctness(quality_scope_rate), +            "unknown_tag_count": unknown, +        }, +        "samples": details, +    } + + +def main() -> None: +    parser = argparse.ArgumentParser(description=__doc__) +    parser.add_argument("--dataset", type=Path, default=DEFAULT_DATASET) +    parser.add_argument("--output", type=Path) +    args = parser.parse_args() +    try: +        report = evaluate(args.dataset) +        output = args.output or args.dataset / "baseline_report.json" +        output.write_text(json.dumps(report, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8") +    except Exception as exc: +        print(str(exc), file=sys.stderr) +        raise SystemExit(2) from exc + + +if __name__ == "__main__": +    main()
