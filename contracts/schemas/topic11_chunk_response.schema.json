{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topic5.local/contracts/topic11_chunk_response.schema.json",
  "title": "Topic 11 to Topic 5 Chunk Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "provider",
    "provider_version",
    "chunks",
    "warnings",
    "trace"
  ],
  "properties": {
    "contract_version": {"const": "1.0"},
    "provider": {"enum": ["topic11", "internal"]},
    "provider_version": {"type": "string", "minLength": 1},
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chunk_id", "text", "source_block_ids"],
        "properties": {
          "chunk_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "source_block_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "entity_ids": {"type": "array", "items": {"type": "string"}},
          "parent_chunk_id": {"type": ["string", "null"]},
          "title_path": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "trace": {"type": "object"}
  }
}
