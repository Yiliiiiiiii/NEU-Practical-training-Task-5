{
  "content_organization": {
    "chunk_strategy": "source_block_aware",
    "enable_parent_child": false,
    "keyword_mode": "deterministic",
    "max_tokens": 1400,
    "min_tokens": 1,
    "overlap_tokens": 0,
    "protect_code_blocks": true,
    "protect_lists": true,
    "protect_tables": true,
    "summary": {
      "chunk_mode": "deterministic",
      "document_mode": "none"
    },
    "target_tokens": 1200
  },
  "mapping_rules": {
    "aliases": {
      "body": [
        "正文",
        "内容",
        "公告内容"
      ],
      "issuer": [
        "发布单位",
        "发布机构",
        "公告单位"
      ],
      "publish_date": [
        "发布日期",
        "发布时间",
        "公开日期"
      ],
      "title": [
        "标题",
        "公告标题",
        "通知标题",
        "document_title"
      ]
    },
    "defaults": {},
    "enum_maps": {},
    "name": "Announcement Document Base Template",
    "regex_rules": [
      {
        "group": 1,
        "pattern": "(?:发布日期|发布时间|公开日期)\\s*[:：]\\s*(\\d{4}[-/.年]\\d{1,2}[-/.月]\\d{1,2})",
        "target_field_id": "publish_date"
      }
    ],
    "schema_id": "announcement_doc",
    "template_id": "announcement_doc_base_v1",
    "transform_rules": [
      {
        "operation": "normalize_date",
        "rule_id": "normalize_publish_date",
        "target_field_id": "publish_date"
      },
      {
        "operation": "trim",
        "rule_id": "trim_title",
        "target_field_id": "title"
      },
      {
        "operation": "trim",
        "rule_id": "trim_issuer",
        "target_field_id": "issuer"
      }
    ],
    "version": "1.0.0"
  },
