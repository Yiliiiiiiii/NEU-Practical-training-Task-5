{
  "schema_id": "general_doc",
  "name": "通用文档标准结构",
  "version": "1.0.0",
  "description": "用于非特定业务类型文档的标准化输出。",
  "fields": [
    {
      "field_id": "title",
      "name": "title",
      "display_name": "标题",
      "type": "string",
      "required": true,
      "aliases": ["标题", "文档标题"],
      "constraints": {"min_length": 1}
    },
    {
      "field_id": "source",
      "name": "source",
      "display_name": "来源",
      "type": "string",
      "required": false,
      "aliases": ["来源", "出处"],
      "constraints": {}
    },
    {
      "field_id": "created_date",
      "name": "created_date",
      "display_name": "创建日期",
      "type": "date",
      "required": false,
      "aliases": ["创建日期", "形成日期"],
      "constraints": {}
    },
    {
      "field_id": "category",
      "name": "category",
      "display_name": "类别",
      "type": "string",
      "required": false,
      "aliases": ["类别", "分类"],
      "constraints": {}
    },
    {
      "field_id": "content",
      "name": "content",
      "display_name": "正文",
      "type": "text",
      "required": true,
      "aliases": ["正文", "内容", "content"],
      "constraints": {}
    },
    {
      "field_id": "tags",
      "name": "tags",
      "display_name": "标签",
      "type": "array[string]",
      "required": false,
      "aliases": ["标签", "关键词"],
      "constraints": {}
    }
  ],
  "json_schema": {
    "type": "object",
    "required": ["title", "content"],
    "properties": {
      "title": {"type": "string"},
      "source": {"type": "string"},
      "created_date": {"type": "string", "format": "date"},
      "category": {"type": "string"},
      "content": {"type": "string"},
      "tags": {"type": "array", "items": {"type": "string"}}
    }
  }
}
