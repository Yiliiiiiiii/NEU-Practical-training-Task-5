      "source_anchor": null,
      "text": "项目名称：广播电视行业网络安全保护管理系统工程监理采购项目",
      "type": "paragraph"
    },
    {
      "attributes": {
        "html_tag": "p"
      },
      "block_id": "real_procurement_001_broadcast_security_supervision_b013",
      "level": null,
      "source_anchor": null,
