      },
      "block_id": "real_procurement_001_broadcast_security_supervision_b030",
      "level": null,
      "source_anchor": null,
      "text": "售价：￥500.0 元，本公告包含的招标文件售价总和",
      "type": "paragraph"
    },
    {
      "attributes": {
        "html_tag": "p"
      },
      "block_id": "real_procurement_001_broadcast_security_supervision_b031",
      "level": null,
      "source_anchor": null,
