{
  "$defs": {
    "AssertionDefaults": {
      "additionalProperties": false,
      "properties": {
        "missing_optional_field": {
          "const": "skip",
          "default": "skip",
          "title": "Missing Optional Field",
          "type": "string"
        },
        "severity": {
          "default": "error",
          "enum": [
            "error",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "title": "AssertionDefaults",
      "type": "object"
    },
    "ConversionAssertionDefinition": {
      "additionalProperties": false,
      "properties": {
        "assertion_id": {
          "title": "Assertion Id",
          "type": "string"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "operator": {
          "enum": [
            "exists",
            "non_empty",
            "type_is",
            "date_format",
            "datetime_format",
            "regex_match",
            "enum_allowed",
            "number_range",
            "text_length",
            "array_length",
            "url_like",
            "equal_to_path",
            "not_equal_to_path"
          ],
          "title": "Operator",
          "type": "string"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        },
        "parameters": {
          "title": "Parameters",
          "type": "object"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "severity": {
          "anyOf": [
            {
              "enum": [
                "error",
                "warning"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity"
        }
      },
      "required": [
        "assertion_id",
        "path",
        "operator"
      ],
      "title": "ConversionAssertionDefinition",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assertion_set_version": {
      "title": "Assertion Set Version",
      "type": "string"
    },
    "assertions": {
      "items": {
        "$ref": "#/$defs/ConversionAssertionDefinition"
      },
      "title": "Assertions",
      "type": "array"
    },
    "contract_version": {
      "title": "Contract Version",
      "type": "string"
    },
    "defaults": {
      "$ref": "#/$defs/AssertionDefaults"
    },
    "schema_id": {
      "title": "Schema Id",
      "type": "string"
    }
  },
  "required": [
    "contract_version",
    "schema_id",
    "assertion_set_version",
    "assertions"
  ],
  "title": "ConversionAssertionConfig",
  "type": "object"
}
